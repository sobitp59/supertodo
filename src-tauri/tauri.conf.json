{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "supertodoapp",
  "version": "0.1.0",
  "identifier": "com.sobitprasad.supertodoapp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": true,
        "title": "supertodoapp",
        "transparent": true,
        "decorations": false,
        "maximized": true,
        "resizable": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*", "**/**", "*"]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
